DOMAIN-SUFFIX,pages.dev
DOMAIN-SUFFIX,videodelivery.net
DOMAIN-SUFFIX,workers.dev
DOMAIN-KEYWORD,cloudflare
DOMAIN-KEYWORD,cdn.cloudflare

# Amazon CloudFront
DOMAIN-SUFFIX,cloudfront.net
DOMAIN-KEYWORD,awscloud
DOMAIN-KEYWORD,cloudfront

